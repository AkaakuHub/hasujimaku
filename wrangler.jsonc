{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hasujimaku",
  "compatibility_date": "2026-07-16",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "routes": [
    {
      "pattern": "hasujimaku.akaaku.net",
      "custom_domain": true,
    },
  ],
}
